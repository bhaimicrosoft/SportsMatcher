rules_version = '2';

// SportsMatcher — Firestore security rules
//
// Posture: deny by default. Each collection has an explicit allowlist of
// fields and required predicates on create/update. Reads are owner-only
// for now; provider read access lands in Phase 1 alongside the role claim.
//
// Note on listing bookings: list operations evaluate the read rule against
// every document the query could return — so any client query against
// `bookings` MUST include `where('userId', '==', auth.uid)`, otherwise
// Firestore rejects it outright. This is intentional.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function isVerified() {
      return isAuthed() && request.auth.token.email_verified == true;
    }
    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ---------- users ----------
    // Each user owns exactly one profile document at users/{their_uid}.
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 320
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoURL',
          'favoriteSports', 'favoriteVenues',
          'biometricEnabled', 'createdAt', '_serverTs'
        ]);

      allow update: if isOwner(uid)
        && unchanged('uid')
        && unchanged('email')
        && unchanged('createdAt')
        && changedKeys().hasOnly([
          'displayName', 'photoURL',
          'favoriteSports', 'favoriteVenues',
          'biometricEnabled', '_serverTs'
        ]);

      // Account deletion goes through a Cloud Function (Phase 1) so we can
      // GDPR/CCPA-export and tombstone bookings atomically.
      allow delete: if false;
    }

    // ---------- bookings ----------
    match /bookings/{id} {
      // Owner-only reads. Provider access added in Phase 1 once the
      // `role: 'provider'` custom claim and `venue.ownerUid` field exist.
      allow read: if isOwner(resource.data.userId);

      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'confirmed'
        && request.resource.data.keys().hasOnly([
          'userId', 'venuePlaceId', 'venueName', 'venueAddress',
          'sport', 'startsAt', 'durationMinutes',
          'courts', 'players', 'notes', 'status', 'createdAt'
        ])
        && request.resource.data.venuePlaceId is string
        && request.resource.data.venuePlaceId.size() > 0
        && request.resource.data.venuePlaceId.size() <= 200
        && request.resource.data.venueName is string
        && request.resource.data.venueName.size() > 0
        && request.resource.data.venueName.size() <= 200
        && request.resource.data.venueAddress is string
        && request.resource.data.venueAddress.size() <= 500
        && request.resource.data.sport in ['pickleball', 'tennis', 'badminton', 'basketball']
        && request.resource.data.startsAt is string
        && request.resource.data.startsAt.size() >= 20
        && request.resource.data.startsAt.size() <= 30
        && request.resource.data.durationMinutes in [30, 60, 90, 120]
        && request.resource.data.courts is int
        && request.resource.data.courts >= 1
        && request.resource.data.courts <= 4
        && request.resource.data.players is int
        && request.resource.data.players >= 1
        && request.resource.data.players <= 12
        && (!('notes' in request.resource.data.keys())
            || (request.resource.data.notes is string
                && request.resource.data.notes.size() <= 1000))
        && request.resource.data.createdAt is string;

      // Owner can only cancel their own booking. Every other field is
      // immutable from the client; mutations like rescheduling will move
      // through a Cloud Function in Phase 2.
      allow update: if isOwner(resource.data.userId)
        && changedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled';

      // Soft-delete via status='cancelled' only.
      allow delete: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
